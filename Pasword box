<!DOCTYPE html>
<html lang="en">

<head>
    <title>Document</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
</head>

<body>
    <div class="row">
        <div class="col-4 m-auto">
            <div class="card">
                <div class="card-header bg-dark text-white text-center">
                    <h1>Password Box</h1>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="checkbox" id="check-box">
                        </div>
                        <input type="password" class="form-control" placeholder="Enter password" id="pw-box">
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        let checkBox=document.getElementById('check-box');
        let pwBox=document.getElementById('pw-box');

        checkBox.addEventListener('change',()=>{
            let ele=pwBox.getAttribute('type');
            if(ele=="password") pwBox.setAttribute('type','text');
            else pwBox.setAttribute('type','password');
        })
    </script>
</body>

</html>
